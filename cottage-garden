      width: 100%;
      aspect-ratio: 2 / 3;
      perspective: 1100px;
      cursor: pointer;
    }

    .card-inner {
      position: absolute;
      inset: 0;
      transition: transform 0.9s ease;
      transform-style: preserve-3d;
    }

    .card.flipped .card-inner {
      transform: rotateY(180deg);
    }

    .card-face {
      position: absolute;
      inset: 0;
      border-radius: 20px;
      overflow: hidden;
      backface-visibility: hidden;
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.32), 0 0 20px rgba(255, 214, 127, 0.1);
