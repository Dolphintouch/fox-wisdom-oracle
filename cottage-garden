    const welcomeScreen = document.getElementById('welcomeScreen');
    const mainSite = document.getElementById('mainSite');
    const enterGardenBtn = document.getElementById('enterGardenBtn');
    const drawOneBtn = document.getElementById('drawOneBtn');
    const drawThreeBtn = document.getElementById('drawThreeBtn');
    const cardsArea = document.getElementById('cardsArea');
    const readingIntro = document.getElementById('readingIntro');

    function createFireflies() {
      const firefliesContainer = document.getElementById('fireflies');
      for (let i = 0; i < 22; i++) {
        const fly = document.createElement('div');
        fly.className = 'firefly';
        fly.style.left = Math.random() * 100 + 'vw';
        fly.style.animationDuration = (10 + Math.random() * 10) + 's';
        fly.style.animationDelay = (Math.random() * 10) + 's';
        fly.style.opacity = (0.35 + Math.random() * 0.6).toFixed(2);
        const size = 4 + Math.random() * 6;
        fly.style.width = size + 'px';
        fly.style.height = size + 'px';
        firefliesContainer.appendChild(fly);
      }
    }

    function shuffle(array) {
      const copy = [...array];
      for (let i = copy.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [copy[i], copy[j]] = [copy[j], copy[i]];
      }
      return copy;
    }

    function createCardElement(card, role = 'single', label = '') {
      const shell = document.createElement('div');
      shell.className = 'card-shell';

      const roleText = label || (role === 'single' ? 'Card Drawn' : role.charAt(0).toUpperCase() + role.slice(1));
      const bodyText = card.roleMeanings?.[role] || card.meaning;

      shell.innerHTML = `
        <div class="card card-glow">
          <div class="card-inner">
            <div class="card-face card-back">
              <span>Tap to reveal<br>${card.name}</span>
            </div>
            <div class="card-face card-front">
              <img src="${card.image}" alt="${card.name}">
            </div>
          </div>
        </div>
        <div class="card-text">
          <div class="card-role">${roleText}</div>
          <h3>${card.name}</h3>
          <p>${bodyText}</p>
          <p class="message-box">“${card.message}”</p>
        </div>
      `;

      const cardElement = shell.querySelector('.card');
      cardElement.addEventListener('click', () => {
        cardElement.classList.toggle('flipped');
      });

      setTimeout(() => {
        cardElement.classList.add('flipped');
      }, 250);

      return shell;
    }

    function drawSingleCard() {
      const card = cards[Math.floor(Math.random() * cards.length)];
      cardsArea.innerHTML = '';
      readingIntro.textContent = 'A single card has stepped forward from the twilight garden.';
      cardsArea.appendChild(createCardElement(card, 'single', 'Garden Guidance'));
    }

    function drawThreeCards() {
      const selected = shuffle(cards).slice(0, 3);
      const roles = ['past', 'present', 'future'];
      const labels = ['Past Root', 'Present Bloom', 'Future Path'];

      cardsArea.innerHTML = '';
      readingIntro.textContent = 'The garden has opened a three-card path for reflection: where you have been, where you stand, and what may be unfolding next.';

      selected.forEach((card, index) => {
        cardsArea.appendChild(createCardElement(card, roles[index], labels[index]));
      });
    }

    enterGardenBtn.addEventListener('click', () => {
      welcomeScreen.classList.add('hidden');
      mainSite.classList.remove('hidden');
      setTimeout(() => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, 150);
    });

    drawOneBtn.addEventListener('click', drawSingleCard);
    drawThreeBtn.addEventListener('click', drawThreeCards);

    createFireflies();
  </script>
