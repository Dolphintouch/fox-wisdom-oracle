        url('cottage-garden-bg.jpg') center/cover no-repeat;
      z-index: -3;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255, 224, 160, 0.08), rgba(0, 0, 0, 0.3));
      z-index: -2;
      pointer-events: none;
    }

    .mist {
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at 20% 30%, rgba(255, 240, 210, 0.08), transparent 30%),
        radial-gradient(circle at 80% 50%, rgba(255, 230, 180, 0.06), transparent 26%),
        radial-gradient(circle at 45% 80%, rgba(255, 245, 230, 0.06), transparent 28%);
      filter: blur(18px);
      animation: driftMist 18s ease-in-out infinite alternate;
      z-index: -1;
      pointer-events: none;
    }

    @keyframes driftMist {
      from { transform: translateX(-10px) translateY(0px) scale(1); }
      to { transform: translateX(10px) translateY(-12px) scale(1.05); }
    }

    .fireflies {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 1;
    }

    .firefly {
      position: absolute;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255, 228, 140, 0.95);
      box-shadow: 0 0 10px rgba(255, 215, 110, 0.95), 0 0 22px rgba(255, 215, 110, 0.55);
      animation: floatFirefly linear infinite;
      opacity: 0.8;
    }

    @keyframes floatFirefly {
      0% {
        transform: translateY(100vh) translateX(0) scale(0.8);
        opacity: 0;
      }
      15% { opacity: 0.9; }
      50% {
        transform: translateY(45vh) translateX(24px) scale(1);
        opacity: 0.7;
      }
      100% {
        transform: translateY(-10vh) translateX(-20px) scale(0.85);
        opacity: 0;
      }
    }

